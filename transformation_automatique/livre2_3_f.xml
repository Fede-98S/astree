        <ref target="fonctionnelle_2_livre_2.html">
          <graphic url="images/fleche_g.gif" rend="img" mimeType="image/gif"/>
          <hi style="float:left; margin-top:6px">Livre 2</hi>
        </ref>
        <ref target="fonctionnelle_2_livre_4.html">
