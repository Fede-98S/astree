        <lb/>
        <ref target="#dorinde">1</ref>
        <ref target="../../../_analyse/personnage_dd.html#4_dorinde">Dorinde</ref>
        <lb/>
        <ref target="#laonice">2</ref>
        <ref target="../../../_analyse/personnage_ll.html#4_laonice">Laonice</ref>
        <ref target="../../../_analyse/personnage_tt.html#4_tircis">Tircis</ref>
